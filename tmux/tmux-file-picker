#!/usr/bin/env bash
#
# Forked from https://github.com/raine/tmux-file-picker/blob/ed9b36a2cd07b7c36ee4817af06859188a1cff63/tmux-file-picker
# All credits to raine (MIT).
#
# Additions on top of the original:
#   - The typed fzf query can re-root the search on the fly, recursing into the
#     whole subtree of wherever it points, just like the base listing:
#       ../       -> search the directory above (../../, ../foo/, ... also work)
#       ~/        -> search the home directory
#       /         -> search the filesystem root
set -euo pipefail

# Absolute path to this script, for re-invoking itself from fzf bindings.
SELF="$0"
case "$SELF" in
	/*) ;;
	*/*) SELF="$PWD/$SELF" ;;
	*) SELF=$(command -v -- "$SELF" || printf '%s' "$PWD/$SELF") ;;
esac

# Called by fzf on every query change. When the query gains a directory prefix
# that re-roots the search (../, ~/ or /), reload the candidate list from the
# deepest directory the query already names, recursing into its whole subtree
# and keeping the typed prefix on each candidate so that both fzf matching and
# the final output stay correct.
_transform_reload() {
	local query="$1"
	local selected_file="${2-}"

	# Choose where to re-root. Prefer the deepest directory the query already
	# names: if the whole query is itself a directory, root there -- so "../work"
	# jumps straight into the work dir instead of listing the parent and filtering
	# (which never surfaces deep matches when the parent is huge). Otherwise root
	# at the part up to the last slash.
	local prefix=""
	case "$query" in
		../* | '~/'* | /*)
			local body="${query%/}" body_path=""
			case "$body" in
				'~')   body_path="$HOME" ;;
				'~/'*) body_path="$HOME/${body#'~/'}" ;;
				/*)    body_path="$body" ;;
				?*)    body_path="$TFP_BASE_DIR/$body" ;;
			esac
			if [[ -n "$body_path" && -d "$body_path" ]]; then
				prefix="$body/"
			elif [[ "$query" == */* ]]; then
				prefix="${query%/*}/"
			fi
			;;
	esac

	# Re-validate: the part up to the last slash might not re-root on its own.
	case "$prefix" in
		../* | '~/'* | /*) ;;
		*) prefix="" ;;
	esac

	# Nothing to do if this is the prefix we last reloaded for.
	if [[ "$prefix" == "$(cat "$TFP_STATE_FILE")" ]]; then
		return 0
	fi

	local dir
	case "$prefix" in
		"") dir="$TFP_BASE_DIR" ;;
		'~/'*) dir="$HOME/${prefix#'~/'}" ;;
		/*) dir="$prefix" ;;
		*) dir="$TFP_BASE_DIR/$prefix" ;;
	esac

	# Keep the current list until the typed prefix points to a real directory.
	if [[ ! -d "$dir" ]]; then
		return 0
	fi

	printf '%s' "$prefix" >"$TFP_STATE_FILE"

	# Carry selections across re-roots. A transform-driven reload wipes fzf's
	# in-list selection (and a re-rooted listing wouldn't contain the previous
	# root's files to keep marked anyway), so persistence is handled out of
	# band: the items selected under the root we're leaving are merged into an
	# accumulator file that main() unions with the final selection on accept.
	# Guard on FZF_SELECT_COUNT -- with nothing selected fzf reports {+f} as the
	# highlighted line, which would otherwise smuggle an unpicked file in. (On
	# fzf too old to export FZF_SELECT_COUNT this just no-ops, leaving the picker
	# working but without cross-root memory.)
	if [[ "${FZF_SELECT_COUNT:-0}" -gt 0 && -n "$selected_file" && -f "$selected_file" ]]; then
		local merged
		merged=$(cat -- "$TFP_SELECTED_FILE" "$selected_file" | awk 'NF && !seen[$0]++')
		printf '%s\n' "$merged" >"$TFP_SELECTED_FILE"
	fi

	# The fd command and flags are referenced as environment variables rather
	# than interpolated into the command string: the reload shell then word-splits
	# them exactly like the initial listing, without brace-expanding a flag such as
	# --exclude "{a,b,c}" into separate words (which fd would treat as bogus search
	# paths, producing an empty list).
	local reload_cmd
	if [[ -z "$prefix" ]]; then
		# Back at the base directory: restore the original listing.
		printf -v reload_cmd 'reload(cd %q && $TFP_FD_CMD $TFP_FD_FLAGS)' "$TFP_BASE_DIR"
	else
		# Re-rooted: recurse into the whole subtree, prefixing each candidate so
		# fzf matching and the final output stay correct. The prefix is exported
		# and read back via awk's ENVIRON rather than substituted into a sed
		# replacement, so a |, & or \ in a directory name can't be mis-parsed as
		# sed delimiter or replacement syntax.
		printf -v reload_cmd 'reload(export TFP_PREFIX=%q; cd %q && $TFP_FD_CMD $TFP_FD_FLAGS | awk '\''{print ENVIRON["TFP_PREFIX"] $0}'\'')' "$prefix" "$dir"
	fi

	# Carried-over picks are no longer visible in the re-rooted list, so report
	# the running count in the header. The text must stay free of parentheses so
	# it can't terminate the change-header action early.
	local kept header=""
	kept=$(wc -l <"$TFP_SELECTED_FILE" 2>/dev/null || printf 0)
	kept=${kept//[[:space:]]/}
	if [[ "$kept" -eq 1 ]]; then
		header="1 file kept from another directory"
	elif [[ "$kept" -gt 1 ]]; then
		header="$kept files kept from other directories"
	fi
	printf '%s+change-header(%s)\n' "$reload_cmd" "$header"
}

_select_zoxide_dir() {
	if ! command -v zoxide >/dev/null 2>&1; then
		echo "Error: Required command 'zoxide' not found. Please install it." >&2
		exit 1
	fi

	local zoxide_preview_cmd='ls -ap --color=always {}'
	if command -v tree >/dev/null 2>&1; then
		# Use tree for a richer preview if available
		zoxide_preview_cmd='tree -C {} | head -n 30'
	fi

	# Use fzf to select directories from zoxide's list.
	# The '|| true' prevents the script from exiting if the user cancels fzf.
	local dirs
	dirs=$(zoxide query -l | fzf --multi --reverse --preview "$zoxide_preview_cmd" || true)
	echo "$dirs"
}

main() {
	if [[ -z "${TMUX-}" ]]; then
		echo "Error: This script must be run inside a tmux session." >&2
		exit 1
	fi

	local pane_id
	local pane_dir
	local pane_pid
	pane_id=$(tmux display-message -p '#{pane_id}')
	pane_dir=$(tmux display-message -p '#{pane_current_path}')
	pane_pid=$(tmux display-message -p '#{pane_pid}')

	# --- Argument Parsing ---
	local use_git_root=false
	local use_zoxide=false
	local dir_only=false
	local select_directories=false
	local path_arg=""

	while [[ $# -gt 0 ]]; do
		case "$1" in
			--git-root|-g)
				use_git_root=true
				shift
				;;
			--zoxide)
				use_zoxide=true
				shift
				;;
			--dir-only)
				dir_only=true
				shift
				;;
			--directories|-d)
				select_directories=true
				shift
				;;
			-*)
				echo "Error: Unknown option '$1'" >&2
				exit 1
				;;
			*)
				if [[ -n "$path_arg" ]]; then
					echo "Error: Only one path argument is allowed." >&2
					exit 1
				fi
				path_arg="$1"
				shift
				;;
		esac
	done

	# Check for conflicting arguments
	if $use_zoxide && [[ -n "$path_arg" ]]; then
		echo "Error: The --zoxide flag cannot be used with a path argument." >&2
		exit 1
	fi

	if $dir_only && ! $use_zoxide; then
		echo "Error: The --dir-only flag can only be used with --zoxide." >&2
		exit 1
	fi

	local search_dirs=()

	if $use_zoxide; then
		local zoxide_output
		zoxide_output=$(_select_zoxide_dir)
		# Exit gracefully if no directory was selected from fzf
		if [[ -z "$zoxide_output" ]]; then
			exit 0
		fi
		# Split multiline output into array
		while IFS= read -r line; do
			[[ -n "$line" ]] && search_dirs+=("$line")
		done <<< "$zoxide_output"
	else
		local search_dir="${path_arg:-$pane_dir}"

		# Convert to absolute path if relative
		if [[ ! "$search_dir" = /* ]]; then
			search_dir="$pane_dir/$search_dir"
		fi

		# Use realpath to resolve ".." and "." components and get a canonical path
		local realpath_cmd="realpath"
		[[ "$OSTYPE" == "darwin"* ]] && realpath_cmd="grealpath"

		if command -v "$realpath_cmd" >/dev/null 2>&1; then
			search_dir=$("$realpath_cmd" -m "$search_dir")
		fi
		search_dirs=("$search_dir")
	fi

	# Verify all directories exist
	for dir in "${search_dirs[@]}"; do
		if [[ ! -d "$dir" ]]; then
			echo "Error: Directory '$dir' does not exist." >&2
			exit 1
		fi
	done

	# --- Mode Detection ---
	local at_prefix_mode=false
	if pgrep -P "$pane_pid" -f ".*claude.*|node.*gemini|codex" >/dev/null; then
		at_prefix_mode=true
	fi

	local git_root
	git_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
	if $use_git_root && [[ -z "$git_root" ]]; then
		echo "Error: --git-root flag used, but not inside a git repository." >&2
		exit 1
	fi

	# If --dir-only is set, just output the directory paths and exit
	if $dir_only; then
		local output_str=""
		if $at_prefix_mode; then
			printf -v output_str "@%s " "${search_dirs[@]}"
		else
			local escaped_paths=()
			for dir in "${search_dirs[@]}"; do
				local escaped
				printf -v escaped "%q" "$dir"
				escaped_paths+=("$escaped")
			done
			output_str=$(printf "%s " "${escaped_paths[@]}")
		fi
		tmux send-keys -t "$pane_id" "$output_str"
		exit 0
	fi

	# --- Command Detection ---
	local fd_cmd
	if command -v fd >/dev/null 2>&1; then
		fd_cmd="fd"
	elif command -v fdfind >/dev/null 2>&1; then
		fd_cmd="fdfind"
	else
		echo "Error: Required command 'fd' or 'fdfind' not found. Please install it." >&2
		exit 1
	fi

	# --- File/Directory Selection ---
	local fd_flags
	local preview_cmd

	# The candidate may carry a ~/ prefix from query re-rooting, so the
	# previews expand a leading ~ themselves.
	if $select_directories; then
		# Directory selection mode
		fd_flags="${TMUX_FILE_PICKER_FD_FLAGS:--H --follow --type d --exclude .git}"

		if command -v tree >/dev/null 2>&1; then
			preview_cmd='p={}; tree -C "${p/#\~/$HOME}" | head -n 30'
		else
			preview_cmd='p={}; ls -ap --color=always "${p/#\~/$HOME}"'
		fi
	else
		# File selection mode (default)
		fd_flags="${TMUX_FILE_PICKER_FD_FLAGS:--H --follow --type f --exclude .git}"

		# The default flags list files only (--type f), but TMUX_FILE_PICKER_FD_FLAGS
		# can override that to include directories, and re-rooting can surface them
		# too -- so the preview views files with the file viewer and falls back to a
		# directory listing when the candidate is a directory.
		local file_viewer
		if command -v bat >/dev/null 2>&1; then
			file_viewer='bat --style=numbers --color=always'
		elif command -v batcat >/dev/null 2>&1; then
			file_viewer='batcat --style=numbers --color=always'
		else
			file_viewer='cat'
		fi
		local dir_viewer
		if command -v tree >/dev/null 2>&1; then
			dir_viewer='tree -C'
		else
			dir_viewer='ls -ap --color=always'
		fi
		preview_cmd='p={}; p="${p/#\~/$HOME}"; if [ -d "$p" ]; then '"$dir_viewer"' "$p" | head -n 30; else '"$file_viewer"' "$p"; fi'
	fi

	local selected_files_str
	if [[ ${#search_dirs[@]} -eq 1 ]]; then
		# Single directory: cd into it for cleaner relative paths in fzf.
		# The change binding re-roots the search when the typed query gains
		# a ../, ~/ or / directory prefix (see _transform_reload), passing the
		# current selection ({+f}) along so it can be carried across the jump.
		# This relies on fzf's change:transform action emitting a reload, so it
		# needs fzf >= 0.36; on older fzf the binding is simply a no-op.
		# Deliberately not local: the EXIT trap reads them after main() returns.
		state_file=$(mktemp)
		selected_file=$(mktemp)
		trap 'rm -f -- "$state_file" "$selected_file"' EXIT
		export TFP_BASE_DIR="${search_dirs[0]}"
		export TFP_FD_CMD="$fd_cmd"
		export TFP_FD_FLAGS="$fd_flags"
		export TFP_STATE_FILE="$state_file"
		export TFP_SELECTED_FILE="$selected_file"
		local self_quoted
		printf -v self_quoted '%q' "$SELF"
		selected_files_str=$(cd "${search_dirs[0]}" && $fd_cmd $fd_flags | fzf --multi --reverse --freeze-right=1 --preview "$preview_cmd" --bind "change:transform:$self_quoted --transform-reload {q} {+f}" || true)
	else
		# Multiple directories: pass them as arguments to fd (returns absolute paths)
		selected_files_str=$($fd_cmd $fd_flags "${search_dirs[@]}" | fzf --multi --reverse --freeze-right=1 --preview "$preview_cmd" || true)
	fi

	if [[ -z "$selected_files_str" ]]; then
		if $use_zoxide; then
			# If zoxide was used but file selection cancelled, continue to output the directories
			:
		else
			exit 0
		fi
	fi

	# Prepend any picks carried over from other roots (single-directory
	# re-rooting; see _transform_reload), dropping duplicates while keeping the
	# carried-over ones first. Done after the cancel check above so that aborting
	# with Esc still discards everything.
	if [[ -n "${selected_file-}" && -s "$selected_file" ]]; then
		selected_files_str=$({ cat -- "$selected_file"; printf '%s\n' "$selected_files_str"; } | awk 'NF && !seen[$0]++')
	fi

	# --- Path Processing ---
	# A leading ~/ on a candidate marks a file the user reached by re-rooting the
	# query to home; expand it to an absolute path here so that home picks come
	# out as real filesystem paths rather than tildes. Picks that were already
	# absolute stay absolute. (The ~/ form is only used for fzf display and
	# matching while re-rooted; it never reaches the output.)
	selected_files=()
	while IFS= read -r line; do
		if [[ -n "$line" ]]; then
			case "$line" in
				'~/'*) selected_files+=("$HOME/${line#'~/'}") ;;
				*)     selected_files+=("$line") ;;
			esac
		fi
	done <<<"$selected_files_str"

	# --- Path Relativization ---
	local relative_paths=()

	# When using zoxide or explicit path arg, return absolute paths
	if $use_zoxide || [[ -n "$path_arg" ]]; then
		if [[ ${#selected_files[@]} -eq 0 ]]; then
			# Fallback: output the directories themselves if no files were selected
			relative_paths=("${search_dirs[@]}")
		elif [[ ${#search_dirs[@]} -eq 1 ]]; then
			# Single directory mode: fd returned relative paths, prepend the
			# directory. Re-rooted candidates are already absolute (/.. or
			# zoxide, or a home pick expanded above) so they are kept as-is.
			local file
			for file in "${selected_files[@]}"; do
				if [[ "$file" = /* ]]; then
					relative_paths+=("$file")
				else
					relative_paths+=("${search_dirs[0]}/$file")
				fi
			done
		else
			# Multiple directories mode: fd returned absolute paths, use as-is
			relative_paths=("${selected_files[@]}")
		fi
	else
		# Standard path relativization logic (non-zoxide always has single directory)
		local search_dir="${search_dirs[0]}"
		local base_dir_for_relativization=""

		if $use_git_root; then
			base_dir_for_relativization="$git_root"
		fi

		if [[ -n "$base_dir_for_relativization" ]]; then
			# We need to calculate relative paths against a specific base directory
			local realpath_cmd="realpath"
			[[ "$OSTYPE" == "darwin"* ]] && realpath_cmd="grealpath"

			# Prepend search directory to each filename to create full paths.
			# Re-rooted candidates are already absolute (including home picks
			# expanded above) so they are used as-is and realpath relativizes
			# them against the git root.
			local full_paths=()
			local file
			for file in "${selected_files[@]}"; do
				case "$file" in
					/*) full_paths+=("$file") ;;
					*)  full_paths+=("$search_dir/$file") ;;
				esac
			done

			while IFS= read -r line; do
				if [[ -n "$line" ]]; then
					relative_paths+=("$line")
				fi
			done < <("$realpath_cmd" --relative-to="$base_dir_for_relativization" "${full_paths[@]}")
		else
			# Paths are already relative to the correct directory (the pane_dir)
			relative_paths=("${selected_files[@]}")
		fi
	fi

	# --- Output Formatting ---
	local files_oneline
	if $at_prefix_mode; then
		# Prefix each file with '@' and join with spaces
		printf -v files_oneline "@%s " "${relative_paths[@]}"
	else
		# Shell-escape each file path and join with spaces
		local escaped_paths=()
		for path in "${relative_paths[@]}"; do
			local escaped
			printf -v escaped "%q" "$path"
			escaped_paths+=("$escaped")
		done
		files_oneline=$(printf "%s " "${escaped_paths[@]}")
	fi

	# --- Send to Tmux ---
	tmux send-keys -t "$pane_id" "$files_oneline"
}

if [[ "${1-}" == "--transform-reload" ]]; then
	_transform_reload "${2-}" "${3-}"
	exit 0
fi

main "$@"
