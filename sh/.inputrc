# Don't immediately execute pasted multiline commands.
set enable-bracketed-paste

# Enable autocompletion.
TAB:menu-complete
set show-all-if-ambiguous on
set menu-complete-display-prefix on

# Make Shift-Tab cycle completions backwards.
"\e[Z":menu-complete-backward

# Append traling slash when tab completing symlinks to directories.
set mark-symlinked-directories on

# Unbind <Esc><Esc> from its default tab complete.
"\e\e":

# Make arrow up/down work based on the currently typed prompt.
"\e[A":history-search-backward
"\e[B":history-search-forward
